<Window x:Class="SPWPFAsync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SPWPFAsync"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <TextBlock FontSize="25" HorizontalAlignment="Center" FontFamily="Bahnschrift" Margin="5">Text analysis</TextBlock>

            <TextBlock FontSize="15" HorizontalAlignment="Center" FontFamily="Bahnschrift" Margin="5">Enter any text:</TextBlock>
            <TextBox x:Name="TextBox" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" HorizontalScrollBarVisibility="Disabled" Height="150" Width="300"></TextBox>

            <Button x:Name="ExecuteButton" Click="ExecuteButton_OnClick" Width="200" FontSize="20" Margin="5">Analyze</Button>
            <Button x:Name="StopButton" Click="StopButton_OnClick" Width="200" FontSize="20" Margin="5">Stop</Button>
        </StackPanel>
    </Grid>
</Window>
